# Example environment variables
# Copy this to .env (do NOT commit secrets) and edit values.

# Backend (Spring Boot)
SPRING_PROFILES_ACTIVE=prod
JAVA_OPTS=-Xmx512m
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Frontend (Next.js) - client-visible vars must start with NEXT_PUBLIC_
NEXT_PUBLIC_API_URL=http://localhost:8080
# Local environment variables for Archflow AI
# Copy this file to .env and set your real secret values.

DB_PASSWORD=your-db-password
JWT_SECRET=your-jwt-secret
GEMINI_API_KEY=your-gemini-api-key
GROQ_API_KEY=your-groq-api-key
DEFAULT_AI_PROVIDER=gemini
